# --- Backend Configuration ---
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_DEBUG=1
# Comma-separated list of allowed hosts (e.g., localhost,127.0.0.1,breathe-esg-assignment-3nq5.onrender.com)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated list of allowed origins for CORS (e.g., http://localhost:5173,https://your-frontend.onrender.com)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database configuration (Defaults to SQLite if DATABASE_ENGINE is not 'postgres')
DATABASE_ENGINE=sqlite
# Or use a single connection string:
DATABASE_URL=postgres://breathe:breathe@localhost:5432/breathe_esg
# Individual variables (fallback):
# POSTGRES_DB=breathe_esg
# POSTGRES_USER=breathe
# POSTGRES_PASSWORD=breathe
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# --- Frontend Configuration ---
# The base URL of the backend API. 
# It can be just the domain (e.g., https://api.yoursite.com) or include the /api prefix.
VITE_API_BASE_URL=http://localhost:8000/api
